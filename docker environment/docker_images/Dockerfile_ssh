FROM ubuntu:latest

# Install SSH server and Python with pexpect
RUN apt update && apt install -y openssh-server python3 python3-pip && \
    pip3 install --break-system-packages pexpect && \
    mkdir /var/run/sshd

# Crea un utente per l'accesso SSH
RUN useradd -m testuser && echo 'testuser:testpass' | chpasswd && \
    useradd -m alice && echo 'alice:alicepass' | chpasswd && \
    useradd -m admin && echo 'admin:passw0rd' | chpasswd

# Permetti login via password
RUN sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config && \
    sed -i 's/PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config

# Espone la porta SSH
EXPOSE 22

# Avvia il server SSH
CMD ["/usr/sbin/sshd", "-D"]
